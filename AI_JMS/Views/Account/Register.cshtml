@using Microsoft.Extensions.Localization

@inject IStringLocalizer<SharedResource> Localizer
@using System.Globalization
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@Localizer["RegisterTitle"] - AI-JMS</title>
    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="~/css/sb-admin-2.min.css" rel="stylesheet">
</head>

<body class="bg-gradient-primary">
    <div class="container">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-5 d-none d-lg-block bg-register-image"></div>
                    <div class="col-lg-7">
                        <div class="p-5">
                            <div class="text-right mb-3" style="font-size: 0.85rem;">
                                <form asp-controller="Account" asp-action="SetLanguage" 
                                      asp-route-returnUrl="@Context.Request.Path" method="post" class="d-inline">
                                    <input type="hidden" name="culture" value="vi" />
                                    <button type="submit" class="btn btn-link btn-sm p-0 @(CultureInfo.CurrentCulture.Name == "vi" ? "font-weight-bold text-primary" : "text-gray-500")">
                                        Tiếng Việt
                                    </button>
                                </form>
                                <span class="text-gray-400 mx-1">|</span>
                                <form asp-controller="Account" asp-action="SetLanguage" 
                                      asp-route-returnUrl="@Context.Request.Path" method="post" class="d-inline">
                                    <input type="hidden" name="culture" value="en" />
                                    <button type="submit" class="btn btn-link btn-sm p-0 @(CultureInfo.CurrentCulture.Name == "en" ? "font-weight-bold text-primary" : "text-gray-500")">
                                        English
                                    </button>
                                </form>
                            </div>

                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">@Localizer["CreateAccount"]</h1>
                            </div>

                            <form class="user" asp-controller="Account" asp-action="Register" method="post">
                                <div class="form-group">
                                    <input type="text" name="FullName" class="form-control form-control-user" 
                                           placeholder="@Localizer["FullName"]" required>
                                </div>
                                <div class="form-group">
                                    <input type="email" name="Email" class="form-control form-control-user" 
                                           placeholder="@Localizer["Email"]" required>
                                </div>
                                <div class="form-group row">
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        <input type="password" name="PasswordHash" class="form-control form-control-user"
                                               placeholder="@Localizer["Password"]" required>
                                    </div>
                                    <div class="col-sm-6">
                                        <input type="password" name="confirmPassword" class="form-control form-control-user"
                                               placeholder="@Localizer["RepeatPassword"]" required>
                                    </div>
                                </div>

                                @if (ViewBag.Error != null)
                                {
                                    <div class="text-danger small mb-3 text-center">@ViewBag.Error</div>
                                }

                                <button type="submit" class="btn btn-primary btn-user btn-block">
                                    @Localizer["RegisterButton"]
                                </button>
                            </form>
                            <hr>
                            <div class="text-center">
                                <span class="small text-gray-600">@Localizer["AlreadyHaveAccount"]</span>
                                <a class="small font-weight-bold" asp-controller="Account" asp-action="Login">
                                    @Localizer["LoginNow"]
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/sb-admin-2.min.js"></script>
</body>

</html>