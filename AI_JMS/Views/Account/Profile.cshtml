@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model AI_JMS.Models.tblUsers
@{
    ViewData["Title"] = Localizer["Profile"];
    // Sử dụng Layout Admin để có Sidebar và Topbar
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; 
}
<div class="container-fluid">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">@Localizer["Profile"]</h1>
    </div>

    <div class="row">
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-body text-center">
                    <div class="py-4">
                        <img class="img-profile rounded-circle mb-3 shadow" 
                             src="~/img/undraw_profile.svg" 
                             style="width:150px; border: 3px solid #f8f9fc;">
                        <h4 class="font-weight-bold text-primary">@Model.FullName</h4>
                        <p class="text-muted"><i class="fas fa-envelope mr-2"></i>@Model.Email</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-user-edit mr-2"></i>@Localizer["PersonalInformation"]
                    </h6>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
                        </div>
                    }

                    <form asp-action="UpdateProfile" asp-controller="Account" method="post">
                        <div class="form-group">
                            <label class="text-gray-700 font-weight-bold">@Localizer["FullName"]</label>
                            <input type="text" name="FullName" value="@Model.FullName" 
                                   class="form-control form-control-user" placeholder="Nhập họ tên...">
                        </div>
                        
                        <div class="form-group">
                            <label class="text-gray-700 font-weight-bold">@Localizer["Email"]</label>
                            <input type="text" value="@Model.Email" class="form-control bg-light" readonly>
                            <small class="text-danger mt-1 d-block"><i class="fas fa-info-circle mr-1"></i>@Localizer["EmailCannotBeChanged"]</small>
                        </div>

                        <hr>
                        <div class="text-right">
                            <button type="submit" class="btn btn-success btn-icon-split shadow-sm">
                                <span class="icon text-white-50"><i class="fas fa-check"></i></span>
                                <span class="text">@Localizer["SaveChanges"]</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>